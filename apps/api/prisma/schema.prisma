generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  GERENTE
  ESTOQUISTA
  FUNCIONARIO
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum MovementType {
  ENTRY
  EXIT
  TRANSFER
  ADJUSTMENT
  MANUAL_CORRECTION
  INVENTORY
  LOSS
  BREAKAGE
  INTERNAL_CONSUMPTION
  RETURN
  EXCHANGE
}

enum PurchaseStatus {
  DRAFT
  BUDGET
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum NotificationType {
  STOCK_MINIMUM
  STOCK_ZERO
  PURCHASE_NEW
  SUCCESS
  ERROR
}

enum BackupStatus {
  PENDING
  SUCCESS
  FAILED
}

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  description     String?
  userPermissions UserPermission[]
  createdAt       DateTime         @default(now())
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  password        String
  active          Boolean          @default(true)
  roleId          String
  role            Role             @relation(fields: [roleId], references: [id])
  permissions     UserPermission[]
  movements       StockMovement[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  purchaseOrders  PurchaseOrder[]
  refreshTokens   RefreshToken[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([roleId])
  @@index([email])
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  permissionId String
  granted      Boolean    @default(true)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Supplier {
  id             String          @id @default(uuid())
  legalName      String
  tradeName      String?
  cnpj           String?
  cpf            String?
  phone          String?
  whatsapp       String?
  email          String?
  address        String?
  contact        String?
  observations   String?
  leadTimeDays   Int             @default(7)
  products       Product[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([legalName])
  @@index([cnpj])
}

model Product {
  id               String            @id @default(uuid())
  internalCode     String            @unique
  barcode          String?
  qrCodeData       String?
  name             String
  description      String?
  categoryId       String
  category         Category          @relation(fields: [categoryId], references: [id])
  brand            String?
  supplierId       String?
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])
  physicalLocation String?
  unit             String            @default("UN")
  purchasePrice    Decimal           @default(0) @db.Decimal(12, 2)
  averagePrice     Decimal           @default(0) @db.Decimal(12, 2)
  salePrice        Decimal           @default(0) @db.Decimal(12, 2)
  minQuantity      Decimal           @default(0) @db.Decimal(12, 3)
  maxQuantity      Decimal?          @db.Decimal(12, 3)
  observations     String?
  imageUrl         String?
  status           ProductStatus     @default(ACTIVE)
  registeredAt     DateTime          @default(now())
  lastMovementAt   DateTime?
  stockBalances    StockBalance[]
  stockBatches     StockBatch[]
  movements        StockMovement[]
  purchaseItems    PurchaseOrderItem[]
  suggestions      PurchaseSuggestion[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([name])
  @@index([barcode])
  @@index([categoryId])
  @@index([supplierId])
  @@index([status])
  @@index([brand])
}

model StockLocation {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  isDefault   Boolean        @default(false)
  balances    StockBalance[]
  batches     StockBatch[]
  movements   StockMovement[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model StockBatch {
  id          String         @id @default(uuid())
  productId   String
  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  batchNumber String
  expiryDate  DateTime?
  locationId  String
  location    StockLocation  @relation(fields: [locationId], references: [id])
  balances    StockBalance[]
  movements   StockMovement[]
  createdAt   DateTime       @default(now())

  @@unique([productId, batchNumber, locationId])
  @@index([expiryDate])
}

model StockBalance {
  id         String        @id @default(uuid())
  productId  String
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId String
  location   StockLocation @relation(fields: [locationId], references: [id])
  batchId    String?
  batch      StockBatch?   @relation(fields: [batchId], references: [id])
  quantity   Decimal       @default(0) @db.Decimal(12, 3)
  updatedAt  DateTime      @updatedAt

  @@unique([productId, locationId, batchId])
  @@index([quantity])
  @@index([productId])
}

model StockMovement {
  id                String        @id @default(uuid())
  type              MovementType
  productId         String
  product           Product       @relation(fields: [productId], references: [id])
  locationId        String
  location          StockLocation @relation(fields: [locationId], references: [id])
  targetLocationId  String?
  batchId           String?
  batch             StockBatch?   @relation(fields: [batchId], references: [id])
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  quantity          Decimal       @db.Decimal(12, 3)
  quantityBefore    Decimal       @db.Decimal(12, 3)
  quantityAfter     Decimal       @db.Decimal(12, 3)
  reason            String?
  observation       String?
  relatedMovementId String?
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  ip                String?
  userAgent         String?
  createdAt         DateTime      @default(now())

  @@index([productId])
  @@index([createdAt])
  @@index([type])
  @@index([userId])
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  supplierId     String
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  userId         String
  user           User                @relation(fields: [userId], references: [id])
  status         PurchaseStatus      @default(DRAFT)
  observations   String?
  invoiceNumber  String?
  receivedAt     DateTime?
  totalAmount    Decimal             @default(0) @db.Decimal(12, 2)
  items          PurchaseOrderItem[]
  movements      StockMovement[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product       @relation(fields: [productId], references: [id])
  quantity         Decimal       @db.Decimal(12, 3)
  receivedQuantity Decimal       @default(0) @db.Decimal(12, 3)
  unitPrice        Decimal       @db.Decimal(12, 2)
  totalPrice       Decimal       @db.Decimal(12, 2)

  @@index([purchaseOrderId])
  @@index([productId])
}

model PurchaseSuggestion {
  id               String   @id @default(uuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  currentStock     Decimal  @db.Decimal(12, 3)
  avgConsumption30 Decimal  @db.Decimal(12, 3)
  avgConsumption90 Decimal  @db.Decimal(12, 3)
  avgConsumption365 Decimal @db.Decimal(12, 3)
  seasonalFactor   Decimal  @default(1) @db.Decimal(5, 2)
  leadTimeDays     Int      @default(7)
  safetyStock      Decimal  @db.Decimal(12, 3)
  suggestedQty     Decimal  @db.Decimal(12, 3)
  generatedAt      DateTime @default(now())

  @@index([productId])
  @@index([generatedAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([entity])
  @@index([entityId])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model BackupLog {
  id        String       @id @default(uuid())
  filename  String
  size      BigInt       @default(0)
  status    BackupStatus @default(PENDING)
  duration  Int?
  error     String?
  createdAt DateTime     @default(now())

  @@index([createdAt])
}
